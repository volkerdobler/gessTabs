{
  "extends": ["plugin:prettier/recommended"],
  "plugins": ["prettier"],
  "rules": {
    "no-console": 2,
    "no-unused-vars": 0,
    "prettier/prettier": [
      "error",
      {
        "trailingComma": "es6",
        "singleQuote": true,
        "printWidth": 80,
        "tabWidth": 2,
      },
    ],
  },
}
